from flask import Flask, render_template, request, redirect
import sqlite3
import matplotlib.pyplot as plt
import os

app = Flask(__name__)

def init_db():
    conn = sqlite3.connect("players.db")
    c = conn.cursor()
    c.execute('''
    CREATE TABLE IF NOT EXISTS players(
        id INTEGER PRIMARY KEY AUTOINCREMENT,
        name TEXT,
        age INTEGER,
        position TEXT,
        speed INTEGER
    )
    ''')
    conn.commit()
    conn.close()
def create_graph(players):
    names = [p[1] for p in players]
    speeds = [p[4] for p in players]

    plt.figure(figsize=(8,4))
    plt.bar(names, speeds)
    plt.title("Player Speed Analysis")
    plt.xlabel("Players")
    plt.ylabel("Speed")

    plt.tight_layout()
    plt.savefig("static/graph.png")
    plt.close()

@app.route("/")
def home():
    return render_template("index.html")

@app.route("/add", methods=["POST"])
def add():
    name = request.form["name"]
    age = request.form["age"]
    position = request.form["position"]
    speed = request.form["speed"]

    conn = sqlite3.connect("players.db")
    c = conn.cursor()
    c.execute("INSERT INTO players(name, age, position, speed) VALUES (?, ?, ?, ?)",
              (name, age, position, speed))
    conn.commit()
    conn.close()

    return redirect("/stats")

@app.route("/stats")
def stats():
    conn = sqlite3.connect("players.db")
    c = conn.cursor()
    c.execute("SELECT * FROM players")
    players = c.fetchall()

    create_graph(players)

    # ANALYSE DESCRIPTIVE
    total = len(players)

    if total > 0:
        ages = [p[2] for p in players]
        speeds = [p[4] for p in players]

        age_moy = sum(ages) / total
        speed_moy = sum(speeds) / total

        best_player = max(players, key=lambda x: x[4])
    else:
        age_moy = 0
        speed_moy = 0
        best_player = None

    conn.close()

    return render_template(
        "stats.html",
        players=players,
        total=total,
        age_moy=round(age_moy, 2),
        speed_moy=round(speed_moy, 2),
        best_player=best_player
    )

   

if __name__ == "__main__":
    init_db()
    app.run(debug=True)
